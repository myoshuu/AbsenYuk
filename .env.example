# ===================
# Database (PostgreSQL via Supabase)
# ===================
# Transaction mode (port 6543) — used by PrismaClient at runtime (serverless)
# Must include ?pgbouncer=true for Supavisor compatibility
DATABASE_URL="your_url"

# Session mode (port 5432) — used by Prisma Migrate (needs full session support)
DIRECT_URL="your_url"

# ===================
# NextAuth
# ===================
# Generate secret with: openssl rand -base64 32
AUTH_SECRET="your-secret-key"
NEXTAUTH_URL="http://localhost:3000"
